generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SeatStatus {
  AVAILABLE
  BOOKED
  BLOCKED
}

enum Role {
  STAFF
  ADMIN
  STUDENT
}

model User {
  id              String    @id @default(uuid())
  name            String
  username        String?   @unique
  displayUsername String?
  email           String    @unique
  emailVerified   Boolean   @default(false)
  image           String?
  role            Role      @default(STAFF)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sessions        Session[]
  accounts        Account[]
  student         Student?
}

model Student {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleId   String   @unique
  email      String   @unique
  name       String
  surname    String
  class      String
  rollNumber Int
  studentId  String   @unique
  qrToken    String   @unique
  seatId     String?  @unique
  seat       Seat?    @relation(fields: [seatId], references: [id])
  createdAt  DateTime @default(now())
}

model Seat {
  id        String     @id
  row       String
  number    Int
  section   String
  type      String
  status    SeatStatus @default(AVAILABLE)
  student   Student?
  bookedBy  String?
  bookedAt  DateTime?
  updatedAt DateTime   @updatedAt

  @@index([row])
  @@index([status])
}

model BookingLog {
  id          String   @id @default(uuid())
  seatId      String
  studentId   String?
  action      String
  performedBy String
  performedAt DateTime @default(now())
  note        String?

  @@index([performedAt])
  @@index([seatId])
  @@index([performedBy])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}
